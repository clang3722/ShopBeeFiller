{
  "manifest_version": 3,
  "name": "店小蜜批量填写助手",
  "version": "2.8",
  "description": "从 Excel 批量填写店小蜜商品数据",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.dianxiaomi.com/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.dianxiaomi.com/*"],
      "js": ["content.js", "floating.js"],
      "css": ["floating.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["xlsx.full.min.js"],
      "matches": ["https://www.dianxiaomi.com/*"]
    }
  ]
}